# Azure AI Content Safety (L1: Prompt Shields, Content Filters, Blocklists)
# ==========================================
CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=your-key-here

# ==========================================
# Azure AI Language (L2: PII Detection, C1: Tool Input Analyzer)
# ==========================================
